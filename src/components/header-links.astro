---
const { class: className } = Astro.props;
const pathname = Astro.url.pathname;

const links = [
  { href: "/", label: "Home" },
  { href: "/download", label: "Download", disabled: true },
  {
    href: "https://github.com/moetorrent/moetorrent/discussions",
    label: "Discussions",
    external: true,
  },
  {
    href: "https://github.com/moetorrent/moetorrent/wiki",
    label: "Wiki",
    external: true,
  },
  {
    href: "https://github.com/moetorrent/moetorrent",
    label: "Development",
    external: true,
  },
  {
    href: "https://github.com/moetorrent/moetorrent/issues",
    label: "Bugs",
    external: true,
  },
];
---

<div
  class:list={[
    "flex flex-wrap items-center justify-center gap-x-4 gap-y-2 px-5 text-sm sm:text-base sm:gap-0 sm:divide-x sm:divide-foreground/20 [&>a]:leading-none sm:[&>a]:px-3 first:[&>a]:pl-0 last:[&>a]:pr-0",
    className,
  ]}
>
  {
    links.map((link) => {
      const isActive =
        !link.external &&
        (pathname === link.href ||
          (link.href !== "/" && pathname.startsWith(link.href)));
      return (
        <a
          href={link.disabled ? undefined : link.href}
          target={link.external ? "_blank" : undefined}
          rel={link.external ? "noopener noreferrer" : undefined}
          class:list={[
            isActive ? "opacity-100 font-medium" : "opacity-75",
            link.disabled
              ? "opacity-35 cursor-not-allowed pointer-events-none select-none"
              : "hover:opacity-100",
          ]}
        >
          {link.label}
        </a>
      );
    })
  }
</div>
