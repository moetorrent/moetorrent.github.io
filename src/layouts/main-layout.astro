---
import HeaderLinks from "../components/header-links.astro";
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>moeTorrent - A cute BitTorrent client</title>
  </head>
  <body class="bg-black text-foreground">
    <div class="fixed -z-999 inset-0 bg-background/90"></div>
    <div
      class="mx-auto select-none w-fit font-bold text-xs mt-10 font-mono bg-background/90 px-2 py-1 rounded-lg border border-foreground/10"
    >
      LATEST: v0.1.1
    </div>
    <h1 class="font-[Bagel_Fat_One] text-6xl mx-auto w-fit my-2 select-none">
      moeTorrent
    </h1>
    <p class="mx-auto w-fit opacity-60">A cute P2P BitTorrent client</p>
    <HeaderLinks class="mt-5" />
    <div
      class="max-w-3xl fixed -z-999 inset-0 border-x border-dashed border-foreground/20 mx-auto"
    >
    </div>
    <div class="w-full border-y border-foreground/20 border-dashed my-5">
      <div
        class:list={[
          "w-full max-w-3xl mx-auto rounded-xl bg-foreground/95 text-dark/90 p-5",
          "prose prose-sm prose-headings:text-dark/90 prose-ul:m-0 prose-li:m-0 prose-p:m-0",
        ]}
      >
        <slot />
      </div>
    </div>
    <footer class="text-center text-foreground/60 text-sm mb-5">
      <a
        href="https://github.com/moetorrent/moetorrent.github.io"
        class="underline text-foreground">Website source</a
      ><br />
      Copyright ©2026 moeTorrent - All rights reserved
    </footer>
  </body>
</html>
